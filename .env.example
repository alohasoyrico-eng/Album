# Álbum — Environment Variables
# Copy this file to .env.local and fill in your API keys.
# The Met Museum and Art Institute of Chicago APIs require NO KEY.
# PoetryDB requires NO KEY.
# The prototype works out-of-the-box with seed data even without any keys.

# === TMDB (The Movie Database) ===
# Free account at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# === Last.fm ===
# Free account at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# === Google Fonts ===
# Free at https://developers.google.com/fonts/docs/developer_api
# Used for font metadata only; fonts load from CDN without a key.
GOOGLE_FONTS_API_KEY=

# === Future: Supabase ===
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Future: PostHog ===
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
